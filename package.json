{
  "name": "robotics-portfolio",
  "version": "1.3.1",
  "description": "Interactive portfolio showcasing robotics engineering expertise, project management experience, and technical skills in autonomous systems and hardware development",
  "author": {
    "name": "Shivam Bhardwaj",
    "email": "contact@shivambhardwaj.com",
    "url": "https://shivambhardwaj.com"
  },
  "homepage": "https://shivambhardwaj.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shivam-Bhardwaj/robotics-portfolio.git"
  },
  "keywords": [
    "robotics",
    "portfolio",
    "nextjs",
    "typescript",
    "framer-motion",
    "tailwindcss",
    "project-management",
    "autonomous-systems",
    "hardware-development",
    "interactive",
    "swarm-robotics"
  ],
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "build:analyze": "ANALYZE=true npm run build",
    "clean": "if exist .next rmdir /s /q .next && if exist out rmdir /s /q out",
    "test": "npx vitest",
    "test:watch": "npx vitest",
    "test:coverage": "npx vitest run --coverage",
    "test:ui": "npx vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:unit": "npx vitest run tests/unit",
    "test:integration": "npx vitest run tests/integration",
    "test:accessibility": "npx vitest run tests/accessibility",
    "test:security": "npx playwright test tests/security/",
    "test:performance": "playwright test --grep @performance",
    "test:all": "npm run test && npm run test:e2e && npm run test:accessibility && npm run test:security",
    "test:ci": "npm run test:coverage && npm run test:e2e && npm run test:security",
    "test:comprehensive": "node scripts/run-comprehensive-tests.js",
    "test:quick": "node scripts/run-comprehensive-tests.js --quick",
    "deploy:safe": "node scripts/run-deploy-agent.js",
    "deploy:staging": "node scripts/run-deploy-agent.js staging",
    "security:audit": "npm audit --audit-level high",
    "security:scan": "node scripts/security-scan.js",
    "validate:pre-push": "node scripts/run-pre-push-agent.js",
    "push:safe": "npm run validate:pre-push && git push",
    "fix:validation": "node scripts/run-validation-fix-agent.js",
    "fix:and-push": "npm run fix:validation && npm run push:safe",
    "fix:dark-mode": "node scripts/run-dark-mode-agent.js",
    "validate:dark-mode": "npm run fix:dark-mode",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:generate": "node scripts/generate-version.js",
    "deploy": "node scripts/deploy.js",
    "deploy:patch": "node scripts/deploy.js patch",
    "deploy:minor": "node scripts/deploy.js minor",
    "deploy:major": "node scripts/deploy.js major",
    "deploy:no-bump": "node scripts/deploy.js --no-bump",
    "manage": "node scripts/manage-app.mjs",
    "claude": "node scripts/claude-helper.js",
    "claude:quick": "node scripts/claude-helper.js quick",
    "claude:context": "node scripts/claude-helper.js context",
    "agent": "node scripts/master-agent.js",
    "agent:list": "node scripts/master-agent.js --list",
    "agent:interactive": "node scripts/master-agent.js --interactive",
    "agent:non-ascii": "node scripts/master-agent.js --agent non-ascii",
    "agent:quality": "node scripts/master-agent.js --agent code-quality",
    "agent:security": "node scripts/master-agent.js --agent security-scan",
    "agent:deps": "node scripts/master-agent.js --agent dependency-audit",
    "agent:a11y": "node scripts/master-agent.js --agent accessibility-audit",
    "agent:performance": "node scripts/master-agent.js --agent performance-audit",
    "agent:tests": "node scripts/master-agent.js --agent test-coverage",
    "agent:docs": "node scripts/master-agent.js --agent documentation-audit",
    "ctx": "node scripts/context-agent/cli.js",
    "ctx:init": "node scripts/context-agent/cli.js init",
    "ctx:terminal": "node scripts/context-agent/terminal-wrapper.js",
    "ctx:claude": "node scripts/context-agent/cli.js claude",
    "ctx:status": "node scripts/context-agent/cli.js status"
  },
  "dependencies": {
    "framer-motion": "^12.23.12",
    "glob": "^11.0.3",
    "lucide-react": "^0.542.0",
    "next": "15.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.40.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "axe-core": "^4.8.2",
    "chalk": "^5.6.0",
    "cross-env": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.4.5",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.1.0",
    "lighthouse": "^11.3.0",
    "playwright": "^1.40.0",
    "playwright-lighthouse": "^4.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5",
    "vite": "^7.1.3",
    "vitest": "^3.2.4",
    "yargs": "^18.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
