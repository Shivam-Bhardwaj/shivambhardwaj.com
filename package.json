{
  "name": "antimony-labs-portfolio",
  "version": "1.0.0",
  "description": "Antimony Labs – Google Cloud deployed robotics & autonomous systems portfolio with enhanced testing and logging",
  "author": "Antimony Labs <contact@shivambhardwaj.com> (https://shivambhardwaj.com)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "clean": "if exist .next rmdir /s /q .next && if exist out rmdir /s /q out && if exist dist rmdir /s /q dist",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:performance": "playwright test --grep @performance",
    "test:security": "playwright test tests/security/",
    "test:accessibility": "vitest run tests/accessibility",
    "test:all": "npm run test:coverage && npm run test:e2e && npm run test:security",
    "test:ci": "npm run test:coverage && npm run test:e2e && npm run test:security",
    "security:audit": "npm audit --audit-level high",
    "security:scan": "node scripts/security-scan.js",
    "deploy:staging": "node scripts/deployment/deploy-staging.cjs",
    "deploy:production": "node scripts/deployment/deploy-production.cjs",
    "deploy:gcp": "gcloud app deploy --quiet",
    "infrastructure:plan": "cd infrastructure/terraform && terraform plan",
    "infrastructure:apply": "cd infrastructure/terraform && terraform apply",
    "infrastructure:destroy": "cd infrastructure/terraform && terraform destroy",
    "logs:view": "gcloud logs read \"resource.type=gae_app\"",
    "logs:tail": "gcloud logs tail \"resource.type=gae_app\"",
    "monitoring:dashboard": "node scripts/monitoring/setup-dashboard.js",
    "setup:gcloud": "node scripts/infrastructure/gcloud-setup.cjs",
    "master": "node scripts/master-controller.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@google-cloud/error-reporting": "^3.0.5",
    "@google-cloud/logging": "^11.0.0",
    "@google-cloud/monitoring": "^4.1.0",
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.10",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "next": "^15.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.1.2",
    "three": "^0.180.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@playwright/test": "^1.40.0",
    "@storybook/addon-a11y": "^9.1.5",
    "@storybook/addon-docs": "^9.1.5",
    "@storybook/addon-onboarding": "^9.1.5",
    "@storybook/addon-vitest": "^9.1.5",
    "@storybook/nextjs-vite": "^9.1.5",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "3.2.4",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.8.2",
    "chalk": "^5.6.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.2",
    "eslint-plugin-storybook": "^9.1.5",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.1.0",
    "lighthouse": "^12.8.2",
    "playwright": "^1.55.0",
    "postcss": "^8",
    "storybook": "^9.1.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "portfolio",
    "nextjs",
    "google-cloud",
    "robotics",
    "typescript",
    "testing",
    "monitoring",
    "logging"
  ],
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
