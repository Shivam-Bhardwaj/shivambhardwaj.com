{
  "extends": [
    "next/core-web-vitals",
    "next/typescript",
    "plugin:storybook/recommended"
  ],
  "rules": {
    "@typescript-eslint/no-explicit-any": "warn",
    "prefer-const": "warn"
  },
  "overrides": [
    {
      "files": [
        "scripts/**/*.cjs"
      ],
      "env": {
        "node": true
      },
      "rules": {
        "@typescript-eslint/no-require-imports": "off",
        "@typescript-eslint/no-var-requires": "off"
      }
    },
    {
      "files": [
        "src/lib/logging.ts"
      ],
      "rules": {
        "@typescript-eslint/no-require-imports": "off",
        "@typescript-eslint/no-explicit-any": "warn"
      }
    },
    {
      "files": [
        "src/lib/robotics/**/*.ts",
        "src/lib/tech/**/*.ts",
        "src/components/**/*.tsx",
        "src/lib/theme/**/*.ts*"
      ],
      "rules": {
        "@typescript-eslint/no-explicit-any": "warn"
      }
    }
  ],
  "ignorePatterns": [
    "scripts/legacy/**/*"
  ]
}